# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI / Gemini Enterprise Configuration
GOOGLE_GENAI_USE_ENTERPRISE=1
GOOGLE_CLOUD_PROJECT=MY_GOOGLE_PROJECT
GOOGLE_CLOUD_PROJECT_NUMBER=MY_GOOGLE_PROJECT_NUMBER
AGENT_RUNTIME_SERVICE_ACCOUNT=service-MY_GOOGLE_PROJECT_NUMBER@gcp-sa-aiplatform-re.iam.gserviceaccount.com
COMPUTE_SERVICE_ACCOUNT=MY_GOOGLE_PROJECT_NUMBER-compute@developer.gserviceaccount.com
GEMINI_ENTERPRISE_INSTANCE=MY_GEMINI_ENTERPRISE_INSTANCE
GEMINI_ENTERPRISE_APP_ID=MY_GEMINI_ENTERPRISE_APP_ID
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_REGION=global

# Zero-Hardcoding Agent & Tool Models
AGENT_MODEL_ID=gemini-3.5-flash
OMNI_MODEL_ID=gemini-omni-flash-preview

# GCS Storage for Video Artifacts
GCS_BUCKET_NAME=MY_GEAPP_BUCKET
LOGS_BUCKET_NAME=MY_GEAPP_BUCKET
