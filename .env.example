# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=marketing-agent-poc-500621
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_REGION=global

# Zero-Hardcoding Agent & Tool Models
AGENT_MODEL_ID=gemini-3.5-flash
OMNI_MODEL_ID=gemini-omni-flash-preview

# GCS Storage for Video Artifacts
GCS_BUCKET_NAME=geapp_agents_storage
LOGS_BUCKET_NAME=geapp_agents_storage
